# Copy to .env.local for `vercel dev`, and set the same vars in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
# Do NOT put real secrets in this file — it is committed. Real values go in .env.local.

# Riot API key — get one at https://developer.riotgames.com (dev keys expire every 24h).
RIOT_API_KEY=

# Optional: GitHub token with the "gist" scope, to sync analyzed data to one private gist.
# Leave blank to disable cloud sync (the app still works with local cache + JSON backup).
GITHUB_GIST_KEY=
